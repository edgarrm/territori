# ── Seguridad de cadena de suministro (npm 11) ─────────────────────

# Enfriamiento: no instalar versiones publicadas hace menos de 7 días.
# En npm el valor es en DÍAS (no segundos). 7 = paranoid mode, razonable
# para software que envías a clientes con baja tolerancia a incidentes.
min-release-age=7

# No ejecutar scripts de ciclo de vida (preinstall/install/postinstall).
ignore-scripts=true

# Fija versiones exactas al hacer npm install <pkg> (sin ^ ni ~).
save-exact=true

# Registro oficial explícito.
registry=https://registry.npmjs.org/